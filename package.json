{
  "name": "texttoapp",
  "version": "1.0.0",
  "description": "Build any app using structured text — powered by AI",
  "main": "server/index.js",
  "scripts": {
    "prestart": "node scripts/kill-port.js",
    "start": "node server/index.js",
    "predev": "node scripts/kill-port.js",
    "dev": "nodemon server/index.js",
    "test": "vitest run --config vitest.config.mjs",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:e2e": "playwright test --config playwright.config.mjs",
    "test:e2e:ui": "playwright test --config playwright.config.mjs --ui",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^21.0.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "docx": "^9.7.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "firebase-admin": "^13.10.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.2",
    "groq-sdk": "^1.2.1",
    "nodemailer": "^8.0.9",
    "openai": "^6.42.0",
    "pdfkit": "^0.18.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
