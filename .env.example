# ─── Antigravity (Google Generative Language — Interactions API) ──
ANTIGRAVITY_API_KEY=AIzaSy_your_google_api_key_here
ANTIGRAVITY_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/interactions
ANTIGRAVITY_AGENT_ID=antigravity-preview-05-2026

# ─── GitHub OAuth App ─────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Must match the callback URL set in your GitHub OAuth App settings
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ─── App ──────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_in_production
PORT=3000
NODE_ENV=development
