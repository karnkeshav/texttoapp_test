# ── AI ─────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey  (create a NEW project first)
GEMINI_API_KEY=

# Antigravity agent ID (leave as-is unless a new version is released)
ANTIGRAVITY_AGENT_ID=antigravity-preview-05-2026

# Model used for code generation (Gemini fallback) and code-quality repairs
# gemini-1.5-flash has a generous free tier; gemini-2.0-flash requires billing
GEMINI_MODEL=gemini-1.5-flash

# Model used for plan-phase JSON analysis (first-message only, cheap call)
PLAN_MODEL=gemini-1.5-flash

# ── GitHub OAuth ───────────────────────────────────────────────────
# Create at https://github.com/settings/developers → OAuth Apps → New
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Local dev:
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
# Production (Render) — uncomment and set:
# GITHUB_CALLBACK_URL=https://your-app.onrender.com/auth/github/callback

# ── Google OAuth ───────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI must include: https://your-app.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local dev:
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Production (Render) — uncomment and set:
# GOOGLE_CALLBACK_URL=https://your-app.onrender.com/auth/google/callback

# ── Session ────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Telemetry ──────────────────────────────────────────────────────
# Public URL of this backend — injected into deployed apps for runtime error reporting.
# If not set, telemetry injection is skipped (apps still work fine).
# Local dev:
BACKEND_ORIGIN=http://localhost:3000
# Production (Render) — uncomment and set to your actual Render URL:
# BACKEND_ORIGIN=https://your-app.onrender.com

# ── Cloudflare Pages (Instant Deploy) ──────────────────────────────
# Required for the "Publish Instantly" deploy path.
# Account ID: Cloudflare dashboard → right sidebar under "Account ID"
CLOUDFLARE_ACCOUNT_ID=
# API Token: dash.cloudflare.com/profile/api-tokens → Create Token
#   → use "Edit Cloudflare Pages" template (grants pages:edit only)
CLOUDFLARE_API_TOKEN=

# ── Firebase / Firestore (user persistence) ────────────────────────
# Required for saving user accounts to Firestore.
# If not set, the server logs a warning and skips persistence — auth still works.
#
# Steps:
#   1. Go to https://console.firebase.google.com → create or open your project
#   2. Project Settings → Service Accounts → Generate new private key
#   3. Copy projectId, clientEmail, and privateKey from the downloaded JSON
#
# IMPORTANT: Render stores the private key on one line — replace all real newlines
# with literal \n when pasting (it looks like: "-----BEGIN RSA PRIVATE KEY-----\nMIIE...")
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
